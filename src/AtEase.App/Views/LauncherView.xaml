<UserControl
    x:Class="AtEase.App.Views.LauncherView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:AtEase.App.Helpers"
    xmlns:models="using:AtEase.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ClassicIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style x:Key="IconGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <helpers:IconImageSourceConverter x:Key="IconImageSourceConverter" />
        <helpers:IconImageVisibilityConverter x:Key="IconImageVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Rectangle Visibility="{Binding WallpaperVisibility}">
            <Rectangle.Fill>
                <ImageBrush ImageSource="{Binding WallpaperImageSource}" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center" />
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Visibility="{Binding FallbackBackgroundVisibility}">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF9A9AA0" Offset="0" />
                    <GradientStop Color="#FF7E7E84" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Fill="#22000000" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Background="#FFE6E6E6" Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="At Ease"
                    Margin="10,0,0,0"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="#FF111111"
                    VerticalAlignment="Center" />

                <MenuBar Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <MenuBarItem Title="File">
                        <MenuFlyoutItem Text="Open Settings" Command="{Binding OpenSettingsFromMenuCommand}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Quit" Command="{Binding QuitCommand}" />
                    </MenuBarItem>

                    <MenuBarItem Title="View">
                        <MenuFlyoutItem Text="Refresh Launcher" Command="{Binding RefreshLauncherViewCommand}" />
                        <MenuFlyoutItem Text="Refresh Background" Command="{Binding RefreshBackgroundCommand}" />
                    </MenuBarItem>

                    <MenuBarItem Title="Special">
                        <MenuFlyoutItem Text="Sleep" Command="{Binding SleepCommand}" />
                        <MenuFlyoutItem Text="Shut Down" Command="{Binding ShutDownCommand}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Exit At Ease" Command="{Binding ExitAtEaseCommand}" />
                        <MenuFlyoutItem Text="Eject Removable Media..." Command="{Binding EjectRemovableMediaCommand}" />
                    </MenuBarItem>

                    <MenuBarItem Title="Panels">
                        <MenuFlyoutItem Text="Apps" Command="{Binding SwitchPanelCommand}" CommandParameter="apps" />
                        <MenuFlyoutItem Text="Folders" Command="{Binding SwitchPanelCommand}" CommandParameter="folders" />
                    </MenuBarItem>
                </MenuBar>

                <TextBlock
                    Grid.Column="3"
                    Text="{Binding ClockText}"
                    Margin="0,0,12,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#FF111111"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right" />
            </Grid>

            <Grid Grid.Row="1" Margin="10,10,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="4" Margin="10,0,0,0">
                    <Border
                        Visibility="{Binding AppsActiveTabVisibility}"
                        Background="#FFD6C3A4"
                        BorderBrush="#FF000000"
                        BorderThickness="1,1,1,0"
                        CornerRadius="10,6,0,0"
                        Margin="0,0,0,-1"
                        Padding="14,3,14,3">
                        <TextBlock Text="Apps" FontSize="13" FontWeight="SemiBold" Foreground="#FF101010" />
                    </Border>

                    <Button
                        Visibility="{Binding AppsInactiveTabVisibility}"
                        Content="Apps"
                        Command="{Binding SwitchPanelCommand}"
                        CommandParameter="apps"
                        Background="#FFC4B398"
                        BorderBrush="#FF000000"
                        BorderThickness="1"
                        CornerRadius="9,6,0,0"
                        Margin="0,3,0,0"
                        Padding="12,3,12,2"
                        FontSize="13"
                        Foreground="#FF161616" />

                    <Border
                        Visibility="{Binding FoldersActiveTabVisibility}"
                        Background="#FFD6C3A4"
                        BorderBrush="#FF000000"
                        BorderThickness="1,1,1,0"
                        CornerRadius="10,6,0,0"
                        Margin="0,0,0,-1"
                        Padding="14,3,14,3">
                        <TextBlock Text="Folders" FontSize="13" FontWeight="SemiBold" Foreground="#FF101010" />
                    </Border>

                    <Button
                        Visibility="{Binding FoldersInactiveTabVisibility}"
                        Content="Folders"
                        Command="{Binding SwitchPanelCommand}"
                        CommandParameter="folders"
                        Background="#FFC4B398"
                        BorderBrush="#FF000000"
                        BorderThickness="1"
                        CornerRadius="9,6,0,0"
                        Margin="0,3,0,0"
                        Padding="12,3,12,2"
                        FontSize="13"
                        Foreground="#FF161616" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFD8C6A9" Offset="0" />
                            <GradientStop Color="#FFD4C1A3" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Border
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        Margin="1"
                        Padding="10,8,10,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Text="{Binding StatusMessage}"
                                FontSize="12"
                                Foreground="#FF2A2A2A"
                                HorizontalAlignment="Right"
                                TextTrimming="CharacterEllipsis" />

                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <ScrollViewer Visibility="{Binding AppsPanelVisibility}">
                                    <StackPanel>
                                        <GridView
                                            ItemsSource="{Binding Apps}"
                                            Visibility="{Binding AppsGridVisibility}"
                                            ItemContainerStyle="{StaticResource IconGridViewItemStyle}"
                                            SelectionMode="None"
                                            IsItemClickEnabled="False"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollMode="Disabled"
                                            HorizontalAlignment="Stretch">
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>

                                            <GridView.ItemTemplate>
                                                <DataTemplate x:DataType="models:AppItem">
                                                    <Button
                                                        Width="90"
                                                        Height="88"
                                                        Margin="3"
                                                        Style="{StaticResource ClassicIconButtonStyle}"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Top"
                                                        Command="{Binding DataContext.AppTileClickCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}">
                                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                            <Grid Width="34" Height="34">
                                                                <Image
                                                                    Width="32"
                                                                    Height="32"
                                                                    Stretch="Uniform"
                                                                    Source="{Binding IconHint, Converter={StaticResource IconImageSourceConverter}}"
                                                                    Visibility="{Binding IconHint, Converter={StaticResource IconImageVisibilityConverter}}" />

                                                                <Grid Visibility="{Binding IconHint, Converter={StaticResource IconImageVisibilityConverter}, ConverterParameter=invert}">
                                                                    <Border
                                                                        Width="28"
                                                                        Height="28"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Background="#FFF0EDE7"
                                                                        BorderBrush="#FF333333"
                                                                        BorderThickness="1" />
                                                                    <Rectangle
                                                                        Width="14"
                                                                        Height="1"
                                                                        Fill="#FF333333"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center" />
                                                                </Grid>
                                                            </Grid>

                                                            <TextBlock
                                                                Text="{x:Bind DisplayName}"
                                                                FontSize="10"
                                                                MaxWidth="82"
                                                                TextAlignment="Center"
                                                                TextWrapping="WrapWholeWords"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>

                                        <TextBlock
                                            Text="No apps configured."
                                            Visibility="{Binding AppsEmptyVisibility}"
                                            Foreground="#FF2A2A2A"
                                            FontSize="12" />
                                    </StackPanel>
                                </ScrollViewer>

                                <ScrollViewer Visibility="{Binding FoldersPanelVisibility}">
                                    <StackPanel>
                                        <GridView
                                            ItemsSource="{Binding Folders}"
                                            Visibility="{Binding FoldersGridVisibility}"
                                            ItemContainerStyle="{StaticResource IconGridViewItemStyle}"
                                            SelectionMode="None"
                                            IsItemClickEnabled="False"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollMode="Disabled"
                                            HorizontalAlignment="Stretch">
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>

                                            <GridView.ItemTemplate>
                                                <DataTemplate x:DataType="models:FolderItem">
                                                    <Button
                                                        Width="90"
                                                        Height="88"
                                                        Margin="3"
                                                        Style="{StaticResource ClassicIconButtonStyle}"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Top"
                                                        Command="{Binding DataContext.FolderTileClickCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}">
                                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                            <Grid Width="34" Height="34">
                                                                <Image
                                                                    Width="32"
                                                                    Height="32"
                                                                    Stretch="Uniform"
                                                                    Source="{Binding IconHint, Converter={StaticResource IconImageSourceConverter}}"
                                                                    Visibility="{Binding IconHint, Converter={StaticResource IconImageVisibilityConverter}}" />

                                                                <Grid Visibility="{Binding IconHint, Converter={StaticResource IconImageVisibilityConverter}, ConverterParameter=invert}">
                                                                    <Border
                                                                        Width="30"
                                                                        Height="22"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Bottom"
                                                                        Background="#FFF0EDE7"
                                                                        BorderBrush="#FF333333"
                                                                        BorderThickness="1" />
                                                                    <Border
                                                                        Width="12"
                                                                        Height="5"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        Margin="5,6,0,0"
                                                                        Background="#FFF0EDE7"
                                                                        BorderBrush="#FF333333"
                                                                        BorderThickness="1" />
                                                                </Grid>
                                                            </Grid>

                                                            <TextBlock
                                                                Text="{x:Bind DisplayName}"
                                                                FontSize="10"
                                                                MaxWidth="82"
                                                                TextAlignment="Center"
                                                                TextWrapping="WrapWholeWords"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>

                                        <TextBlock
                                            Text="No folders configured."
                                            Visibility="{Binding FoldersEmptyVisibility}"
                                            Foreground="#FF2A2A2A"
                                            FontSize="12" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
