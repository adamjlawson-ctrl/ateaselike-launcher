<UserControl
    x:Class="AtEase.App.Views.LauncherView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:AtEase.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Text="Launcher"
                FontSize="34"
                FontWeight="SemiBold"
                VerticalAlignment="Center" />

            <Button
                Grid.Column="1"
                Content="Settings"
                Command="{Binding OpenSettingsCommand}"
                VerticalAlignment="Center" />
        </Grid>

        <Border
            Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,14">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="WrapWholeWords" />
        </Border>

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="20">
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Apps" FontSize="20" FontWeight="SemiBold" />

                        <GridView
                            ItemsSource="{Binding Apps}"
                            Visibility="{Binding AppsGridVisibility}"
                            SelectionMode="None"
                            IsItemClickEnabled="False"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            HorizontalAlignment="Stretch">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>

                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:AppItem">
                                    <Button
                                        Width="220"
                                        Height="120"
                                        Padding="16"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Command="{Binding DataContext.AppTileClickCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                        <StackPanel VerticalAlignment="Center" Spacing="8">
                                            <SymbolIcon Symbol="AllApps" Width="26" Height="26" />
                                            <TextBlock Text="{x:Bind DisplayName}" TextWrapping="WrapWholeWords" FontSize="16" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <TextBlock
                            Text="No apps configured."
                            Visibility="{Binding AppsEmptyVisibility}"
                            Opacity="0.75" />
                    </StackPanel>
                </Border>

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Folders" FontSize="20" FontWeight="SemiBold" />

                        <GridView
                            ItemsSource="{Binding Folders}"
                            Visibility="{Binding FoldersGridVisibility}"
                            SelectionMode="None"
                            IsItemClickEnabled="False"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            HorizontalAlignment="Stretch">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>

                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:FolderItem">
                                    <Button
                                        Width="220"
                                        Height="120"
                                        Padding="16"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Command="{Binding DataContext.FolderTileClickCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                        <StackPanel VerticalAlignment="Center" Spacing="8">
                                            <SymbolIcon Symbol="Folder" Width="26" Height="26" />
                                            <TextBlock Text="{x:Bind DisplayName}" TextWrapping="WrapWholeWords" FontSize="16" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <TextBlock
                            Text="No folders configured."
                            Visibility="{Binding FoldersEmptyVisibility}"
                            Opacity="0.75" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
